<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>Sửa cuộc họp</title>

    <link rel="stylesheet" href="/css/app.css">

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f5f6f8;
            color: #111827;
        }

        .page {
            max-width: 1050px;
            margin: 35px auto;
            padding: 0 20px;
        }

        .top-actions {
            margin-bottom: 18px;
        }

        .back-link {
            color: #374151;
            text-decoration: none;
            font-weight: 600;
        }

        .card {
            background: white;
            border: 1px solid #e5e7eb;
            border-radius: 16px;
            padding: 32px;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05);
        }

        .header {
            margin-bottom: 28px;
        }

        .header h1 {
            margin: 0 0 8px;
            font-size: 28px;
        }

        .header p {
            margin: 0;
            color: #6b7280;
        }

        .error {
            margin-bottom: 22px;
            padding: 14px 16px;
            border: 1px solid #fecaca;
            border-radius: 10px;
            background: #fef2f2;
            color: #991b1b;
            line-height: 1.5;
        }

        .section-title {
            margin: 28px 0 18px;
            padding-bottom: 10px;
            border-bottom: 1px solid #e5e7eb;
            font-size: 18px;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 20px;
        }

        .form-group {
            min-width: 0;
        }

        .full-width {
            grid-column: 1 / -1;
        }

        label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
        }

        .required {
            color: #dc2626;
        }

        input,
        textarea,
        select {
            width: 100%;
            padding: 12px 13px;
            border: 1px solid #d1d5db;
            border-radius: 9px;
            background: white;
            font: inherit;
            color: #111827;
            outline: none;
        }

        input:focus,
        textarea:focus,
        select:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
        }

        textarea {
            min-height: 110px;
            resize: vertical;
        }

        select[multiple] {
            min-height: 210px;
        }

        .help-text {
            display: block;
            margin-top: 7px;
            color: #6b7280;
            font-size: 13px;
            line-height: 1.5;
        }

        .actions {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            margin-top: 30px;
            padding-top: 22px;
            border-top: 1px solid #e5e7eb;
        }

        .button {
            display: inline-block;
            padding: 12px 19px;
            border: none;
            border-radius: 9px;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
        }

        .button-secondary {
            background: #e5e7eb;
            color: #111827;
        }

        .button-primary {
            background: #111827;
            color: white;
        }

        .button-primary:hover {
            background: #374151;
        }

        @media (max-width: 750px) {
            .page {
                margin: 20px auto;
                padding: 0 12px;
            }

            .card {
                padding: 22px 16px;
            }

            .grid {
                grid-template-columns: 1fr;
            }

            .full-width {
                grid-column: auto;
            }

            .actions {
                flex-direction: column-reverse;
            }

            .button {
                width: 100%;
                text-align: center;
            }
        }
    </style>
</head>

<body>
    <main class="page">
        <div class="top-actions">
            <a
                href="/meetings/<%= meeting.id %>"
                class="back-link"
            >
                ← Quay lại chi tiết cuộc họp
            </a>
        </div>

        <section class="card">
            <div class="header">
                <h1>Sửa cuộc họp</h1>

                <p>
                    Cập nhật thông tin, thời gian, phòng họp và người tham gia.
                </p>
            </div>

            <% if (error) { %>
                <div class="error">
                    <strong>Không thể cập nhật cuộc họp:</strong>
                    <br>
                    <%= error %>
                </div>
            <% } %>

            <form
                action="/meetings/<%= meeting.id %>/edit"
                method="POST"
            >
                <h2 class="section-title">
                    Thông tin cơ bản
                </h2>

                <div class="grid">
                    <div class="form-group full-width">
                        <label for="title">
                            Tiêu đề cuộc họp
                            <span class="required">*</span>
                        </label>

                        <input
                            id="title"
                            type="text"
                            name="title"
                            maxlength="200"
                            value="<%= meeting.title || '' %>"
                            required
                        >
                    </div>

                    <div class="form-group full-width">
                        <label for="description">
                            Mô tả
                        </label>

                        <textarea
                            id="description"
                            name="description"
                        ><%= meeting.description || '' %></textarea>
                    </div>

                    <div class="form-group">
                        <label for="location">
                            Địa điểm
                            <span class="required">*</span>
                        </label>

                        <input
                            id="location"
                            type="text"
                            name="location"
                            maxlength="200"
                            value="<%= meeting.location || '' %>"
                            required
                        >
                    </div>

                    <div class="form-group">
                        <label for="room">
                            Phòng họp
                            <span class="required">*</span>
                        </label>

                        <input
                            id="room"
                            type="text"
                            name="room"
                            maxlength="50"
                            value="<%= meeting.room || '' %>"
                            placeholder="Ví dụ: A301"
                            required
                        >
                    </div>

                    <div class="form-group">
                        <label for="organizer_id">
                            Người tổ chức
                            <span class="required">*</span>
                        </label>

                        <select
                            id="organizer_id"
                            name="organizer_id"
                            required
                        >
                            <option value="">
                                -- Chọn người tổ chức --
                            </option>

                            <% employees.forEach(employee => { %>
                                <option
                                    value="<%= employee.id %>"
                                    <%= Number(meeting.organizer_id) === Number(employee.id)
                                        ? "selected"
                                        : "" %>
                                >
                                    <%= employee.full_name %>

                                    <% if (employee.department) { %>
                                        - <%= employee.department %>
                                    <% } %>
                                </option>
                            <% }) %>
                        </select>
                    </div>
                </div>

                <h2 class="section-title">
                    Thời gian cuộc họp
                </h2>

                <div class="grid">
                    <div class="form-group">
                        <label for="meeting_date">
                            Ngày họp
                            <span class="required">*</span>
                        </label>

                        <input
                            id="meeting_date"
                            type="date"
                            name="meeting_date"
                            value="<%
                                const dateValue = meeting.meeting_date
                                    ? new Date(meeting.meeting_date)
                                        .toISOString()
                                        .split('T')[0]
                                    : '';
                            %><%= dateValue %>"
                            required
                        >
                    </div>

                    <div class="form-group"></div>

                    <div class="form-group">
                        <label for="start_time">
                            Giờ bắt đầu
                            <span class="required">*</span>
                        </label>

                        <input
                            id="start_time"
                            type="time"
                            name="start_time"
                            value="<%= meeting.start_time
                                ? String(meeting.start_time).substring(0, 5)
                                : '' %>"
                            required
                        >
                    </div>

                    <div class="form-group">
                        <label for="end_time">
                            Giờ kết thúc
                            <span class="required">*</span>
                        </label>

                        <input
                            id="end_time"
                            type="time"
                            name="end_time"
                            value="<%= meeting.end_time
                                ? String(meeting.end_time).substring(0, 5)
                                : '' %>"
                            required
                        >
                    </div>
                </div>

                <h2 class="section-title">
                    Người tham gia
                </h2>

                <div class="grid">
                    <div class="form-group full-width">
                        <label for="participants">
                            Nhân viên được mời
                            <span class="required">*</span>
                        </label>

                        <select
                            id="participants"
                            name="participants"
                            multiple
                            required
                        >
                            <% employees.forEach(employee => { %>
                                <option
                                    value="<%= employee.id %>"
                                    <%= selectedParticipants
                                        .map(Number)
                                        .includes(Number(employee.id))
                                        ? "selected"
                                        : "" %>
                                >
                                    <%= employee.full_name %>

                                    <% if (employee.department) { %>
                                        - <%= employee.department %>
                                    <% } %>

                                    <% if (employee.position) { %>
                                        - <%= employee.position %>
                                    <% } %>
                                </option>
                            <% }) %>
                        </select>

                        <span class="help-text">
                            Giữ Ctrl để chọn nhiều nhân viên. Người tổ chức
                            không được nằm trong danh sách người tham gia.
                        </span>
                    </div>
                </div>

                <div class="actions">
                    <a
                        href="/meetings/<%= meeting.id %>"
                        class="button button-secondary"
                    >
                        Hủy thay đổi
                    </a>

                    <button
                        type="submit"
                        class="button button-primary"
                    >
                        Lưu thay đổi
                    </button>
                </div>
            </form>
        </section>
    </main>

    <script>
        const meetingDateInput =
            document.getElementById("meeting_date");

        const organizerSelect =
            document.getElementById("organizer_id");

        const participantSelect =
            document.getElementById("participants");

        // Không cho chọn ngày quá khứ
        const today = new Date();

        const localToday = [
            today.getFullYear(),
            String(today.getMonth() + 1).padStart(2, "0"),
            String(today.getDate()).padStart(2, "0")
        ].join("-");

        meetingDateInput.min = localToday;

        // Không cho chọn người tổ chức trong danh sách tham gia
        function updateParticipantOptions() {
            const organizerId = organizerSelect.value;

            Array.from(participantSelect.options).forEach(option => {
                const isOrganizer =
                    organizerId &&
                    option.value === organizerId;

                option.disabled = isOrganizer;

                if (isOrganizer) {
                    option.selected = false;
                }
            });
        }

        organizerSelect.addEventListener(
            "change",
            updateParticipantOptions
        );

        updateParticipantOptions();
    </script>
</body>
</html>