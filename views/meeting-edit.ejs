<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1"
    >

    <title>Sửa cuộc họp</title>

    <link
        rel="stylesheet"
        href="/css/app.css"
    >
</head>

<body>
    <header class="app-shell-header">
        <div class="app-shell-top">
            <div class="shell-inner">
                <a
                    href="/"
                    class="app-shell-brand"
                >
                    <span class="brand-mark">▣</span>
                    <span>Hệ Thống Đặt Lịch Họp</span>
                </a>

                <a
                    href="/meetings/create"
                    class="shell-create"
                >
                    ＋ Tạo Cuộc Họp
                </a>
            </div>
        </div>

        <nav class="app-shell-nav">
            <div class="nav-inner">
                <a
                    class="nav-link"
                    href="/"
                >
                    Trang Chủ
                </a>

                <a
                    class="nav-link active"
                    href="/meetings"
                >
                    Danh Sách Cuộc Họp
                </a>
            </div>
        </nav>
    </header>

    <main class="page-shell">
        <a
            href="/meetings/<%= meeting.id %>"
            class="back-link"
        >
            ←
        </a>

        <div class="form-title-row">
            <h1>Sửa Cuộc Họp</h1>
            <p>Cập nhật thông tin cuộc họp</p>
        </div>

        <% if (error) { %>
            <div class="alert alert-error">
                <strong>Không thể cập nhật cuộc họp:</strong>
                <br>
                <%= error %>
            </div>
        <% } %>

        <%
            const safeRooms =
                Array.isArray(rooms)
                    ? rooms
                    : [];

            const locations = [
                ...new Set(
                    safeRooms.map(room => room.location)
                )
            ];

            const participantIds =
                Array.isArray(selectedParticipants)
                    ? selectedParticipants.map(Number)
                    : [];

            let dateValue = "";

            if (meeting.meeting_date) {
                const meetingDate =
                    new Date(meeting.meeting_date);

                if (!Number.isNaN(meetingDate.getTime())) {
                    dateValue =
                        meetingDate
                            .toISOString()
                            .slice(0, 10);
                }
            }
        %>

        <form
            action="/meetings/<%= meeting.id %>/edit"
            method="POST"
            class="meeting-form-grid"
        >
            <section class="card form-panel">
                <h2>Thông Tin Cơ Bản</h2>

                <p class="panel-note">
                    Cập nhật thông tin chi tiết về cuộc họp
                </p>

                <div class="field-stack">
                    <div>
                        <label for="title">
                            Tiêu đề cuộc họp
                            <span class="required">*</span>
                        </label>

                        <input
                            id="title"
                            type="text"
                            name="title"
                            maxlength="200"
                            value="<%= meeting.title || '' %>"
                            required
                        >
                    </div>

                    <div>
                        <label for="description">
                            Mô tả
                        </label>

                        <textarea
                            id="description"
                            name="description"
                        ><%= meeting.description || '' %></textarea>
                    </div>

                    <div>
                        <label for="organizer_id">
                            Người tổ chức
                            <span class="required">*</span>
                        </label>

                        <select
                            id="organizer_id"
                            name="organizer_id"
                            required
                        >
                            <option value="">
                                -- Chọn người tổ chức --
                            </option>

                            <% employees.forEach(employee => { %>
                                <option
                                    value="<%= employee.id %>"
                                    <%= Number(meeting.organizer_id) === Number(employee.id)
                                        ? "selected"
                                        : "" %>
                                >
                                    <%= employee.full_name %>

                                    <% if (employee.department) { %>
                                        - <%= employee.department %>
                                    <% } %>
                                </option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="field-row">
                        <div>
                            <label for="location">
                                Địa điểm
                                <span class="required">*</span>
                            </label>

                            <select
                                id="location"
                                name="location"
                                required
                            >
                                <option value="">
                                    -- Chọn địa điểm --
                                </option>

                                <% locations.forEach(location => { %>
                                    <option
                                        value="<%= location %>"
                                        <%= meeting.location === location
                                            ? "selected"
                                            : "" %>
                                    >
                                        <%= location %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>

                        <div>
                            <label for="room">
                                Phòng họp
                                <span class="required">*</span>
                            </label>

                            <select
                                id="room"
                                name="room"
                                required
                            >
                                <option value="">
                                    -- Chọn phòng họp --
                                </option>
                            </select>
                        </div>
                    </div>
                </div>
            </section>

            <div class="form-right-stack">
                <section class="card form-panel">
                    <h2>Thời Gian</h2>

                    <p class="panel-note">
                        Cập nhật ngày và giờ cho cuộc họp
                    </p>

                    <div class="field-stack">
                        <div>
                            <label for="meeting_date">
                                Ngày
                                <span class="required">*</span>
                            </label>

                            <input
                                id="meeting_date"
                                type="date"
                                name="meeting_date"
                                value="<%= dateValue %>"
                                required
                            >
                        </div>

                        <%
                            const selectedStartTime =
                                String(meeting.start_time || "")
                                    .substring(0, 5);

                            const selectedEndTime =
                                String(meeting.end_time || "")
                                    .substring(0, 5);
                        %>

                        <div class="field-row">
                            <div>
                                <label for="start_time">
                                    Giờ bắt đầu
                                    <span class="required">*</span>
                                </label>

                                <select id="start_time" name="start_time" required>
                                    <option value="">-- Chọn giờ bắt đầu --</option>

                                    <% for (let hour = 0; hour < 24; hour++) { %>
                                        <% for (let minute = 0; minute < 60; minute += 30) { %>
                                            <%
                                                const timeValue =
                                                    String(hour).padStart(2, "0") +
                                                    ":" +
                                                    String(minute).padStart(2, "0");
                                            %>

                                            <option
                                                value="<%= timeValue %>"
                                                <%= selectedStartTime === timeValue
                                                    ? "selected"
                                                    : "" %>
                                            >
                                                <%= timeValue %>
                                            </option>
                                        <% } %>
                                    <% } %>
                                </select>
                            </div>

                            <div>
                                <label for="end_time">
                                    Giờ kết thúc
                                    <span class="required">*</span>
                                </label>

                                <select id="end_time" name="end_time" required>
                                    <option value="">-- Chọn giờ kết thúc --</option>

                                    <% for (let hour = 0; hour < 24; hour++) { %>
                                        <% for (let minute = 0; minute < 60; minute += 30) { %>
                                            <%
                                                const timeValue =
                                                    String(hour).padStart(2, "0") +
                                                    ":" +
                                                    String(minute).padStart(2, "0");
                                            %>

                                            <option
                                                value="<%= timeValue %>"
                                                <%= selectedEndTime === timeValue
                                                    ? "selected"
                                                    : "" %>
                                            >
                                                <%= timeValue %>
                                            </option>
                                        <% } %>
                                    <% } %>
                                </select>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="card form-panel participant-picker">
                    <h2>Người Tham Gia</h2>

                    <p class="panel-note">
                        Cập nhật người tham dự cuộc họp
                    </p>

                    <div class="field-stack">
                        <div>
                            <label for="participants">
                                Nhân viên được mời
                                <span class="required">*</span>
                            </label>

                            <select
                                id="participants"
                                name="participants"
                                multiple
                                required
                            >
                                <% employees.forEach(employee => { %>
                                    <option
                                        value="<%= employee.id %>"
                                        <%= participantIds.includes(
                                            Number(employee.id)
                                        )
                                            ? "selected"
                                            : "" %>
                                    >
                                        <%= employee.full_name %>

                                        <% if (employee.department) { %>
                                            - <%= employee.department %>
                                        <% } %>

                                        <% if (employee.position) { %>
                                            - <%= employee.position %>
                                        <% } %>
                                    </option>
                                <% }) %>
                            </select>

                            <span class="help-text">
                                Giữ Ctrl để chọn nhiều nhân viên.
                                Người tổ chức không được chọn trong
                                danh sách người tham gia.
                            </span>
                        </div>
                    </div>
                </section>
            </div>

            <div class="form-actions">
                <a
                    href="/meetings/<%= meeting.id %>"
                    class="button button-secondary"
                >
                    Hủy
                </a>

                <button
                    type="submit"
                    class="button button-primary"
                >
                    Lưu Thay Đổi
                </button>
            </div>
        </form>
    </main>

    <script
        id="meeting-rooms-data"
        type="application/json"
    ><%- JSON.stringify(safeRooms).replace(/</g, "\\u003c") %></script>

    <script
        id="previous-room-data"
        type="application/json"
    ><%- JSON.stringify(meeting.room || "").replace(/</g, "\\u003c") %></script>

    <script>
        const meetingDateInput =
            document.getElementById("meeting_date");

        const organizerSelect =
            document.getElementById("organizer_id");

        const participantSelect =
            document.getElementById("participants");

        const locationSelect =
            document.getElementById("location");

        const roomSelect =
            document.getElementById("room");

        const meetingRooms = JSON.parse(
            document
                .getElementById("meeting-rooms-data")
                .textContent
        );

        const previousRoom = JSON.parse(
            document
                .getElementById("previous-room-data")
                .textContent
        );

        // Không cho chọn ngày trong quá khứ
        const today = new Date();

        const localToday = [
            today.getFullYear(),
            String(today.getMonth() + 1).padStart(2, "0"),
            String(today.getDate()).padStart(2, "0")
        ].join("-");

        if (meetingDateInput) {
            meetingDateInput.min = localToday;
        }

        // Không cho chọn người tổ chức trong danh sách tham gia
        function updateParticipantOptions() {
            if (!organizerSelect || !participantSelect) {
                return;
            }

            const organizerId =
                organizerSelect.value;

            Array.from(
                participantSelect.options
            ).forEach(option => {
                const isOrganizer =
                    organizerId &&
                    option.value === organizerId;

                option.disabled =
                    Boolean(isOrganizer);

                if (isOrganizer) {
                    option.selected = false;
                }
            });
        }

        // Tải phòng theo địa điểm
        function loadRooms() {
            if (!locationSelect || !roomSelect) {
                return;
            }

            const selectedLocation =
                locationSelect.value;

            roomSelect.innerHTML =
                '<option value="">-- Chọn phòng họp --</option>';

            const filteredRooms =
                meetingRooms.filter(
                    room =>
                        room.location === selectedLocation
                );

            filteredRooms.forEach(room => {
                const option =
                    document.createElement("option");

                option.value =
                    room.room_name;

                option.textContent =
                    room.room_name +
                    (
                        room.capacity
                            ? ` - ${room.capacity} người`
                            : ""
                    );

                option.selected =
                    room.room_name === previousRoom;

                roomSelect.appendChild(option);
            });

            roomSelect.disabled =
                !selectedLocation;
        }

        if (organizerSelect) {
            organizerSelect.addEventListener(
                "change",
                updateParticipantOptions
            );
        }

        if (locationSelect) {
            locationSelect.addEventListener(
                "change",
                () => {
                    loadRooms();
                }
            );
        }

        updateParticipantOptions();
        loadRooms();
    </script>
</body>

</html>