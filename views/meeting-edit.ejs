<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sửa cuộc họp</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f6f7f9;
        }

        .container {
            max-width: 900px;
            margin: 35px auto;
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 18px rgba(0,0,0,0.06);
        }

        .grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 18px;
        }

        .full {
            grid-column: 1 / -1;
        }

        label {
            display: block;
            margin-bottom: 7px;
            font-weight: bold;
        }

        input,
        textarea,
        select {
            width: 100%;
            padding: 11px;
            box-sizing: border-box;
            border: 1px solid #d1d5db;
            border-radius: 7px;
        }

        textarea {
            min-height: 100px;
        }

        select[multiple] {
            min-height: 180px;
        }

        .error {
            background: #fee2e2;
            color: #991b1b;
            padding: 12px;
            border-radius: 7px;
            margin-bottom: 18px;
        }

        .actions {
            margin-top: 24px;
            display: flex;
            gap: 10px;
        }

        button,
        .back {
            padding: 11px 18px;
            border-radius: 7px;
            border: none;
            text-decoration: none;
            cursor: pointer;
        }

        button {
            background: #111827;
            color: white;
        }

        .back {
            background: #e5e7eb;
            color: #111827;
        }

        @media (max-width: 700px) {
            .grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <h1>Sửa cuộc họp</h1>

        <% if (error) { %>
            <div class="error"><%= error %></div>
        <% } %>

        <form
            action="/meetings/<%= meeting.id %>/edit"
            method="POST"
        >
            <div class="grid">
                <div class="full">
                    <label>Tiêu đề *</label>
                    <input
                        type="text"
                        name="title"
                        value="<%= meeting.title %>"
                        required
                    >
                </div>

                <div class="full">
                    <label>Mô tả</label>
                    <textarea name="description"><%= meeting.description || "" %></textarea>
                </div>

                <div>
                    <label>Ngày họp *</label>
                    <input
                        type="date"
                        name="meeting_date"
                        value="<%= new Date(meeting.meeting_date).toISOString().split('T')[0] %>"
                        required
                    >
                </div>

                <div>
                    <label>Địa điểm *</label>
                    <input
                        type="text"
                        name="location"
                        value="<%= meeting.location %>"
                        required
                    >
                </div>

                <div>
                    <label>Giờ bắt đầu *</label>
                    <input
                        type="time"
                        name="start_time"
                        value="<%= meeting.start_time.substring(0, 5) %>"
                        required
                    >
                </div>

                <div>
                    <label>Giờ kết thúc *</label>
                    <input
                        type="time"
                        name="end_time"
                        value="<%= meeting.end_time.substring(0, 5) %>"
                        required
                    >
                </div>

                <div>
                    <label>Người tổ chức *</label>

                    <select name="organizer_id" required>
                        <% employees.forEach(employee => { %>
                            <option
                                value="<%= employee.id %>"
                                <%= Number(meeting.organizer_id) === Number(employee.id)
                                    ? "selected"
                                    : "" %>
                            >
                                <%= employee.full_name %>
                            </option>
                        <% }) %>
                    </select>
                </div>

                <div>
                    <label>Người tham gia *</label>

                    <select name="participants" multiple required>
                        <% employees.forEach(employee => { %>
                            <option
                                value="<%= employee.id %>"
                                <%= selectedParticipants
                                    .map(Number)
                                    .includes(Number(employee.id))
                                    ? "selected"
                                    : "" %>
                            >
                                <%= employee.full_name %>
                            </option>
                        <% }) %>
                    </select>

                    <small>Giữ Ctrl để chọn nhiều người.</small>
                </div>
            </div>

            <div class="actions">
                <button type="submit">Lưu thay đổi</button>

                <a
                    href="/meetings/<%= meeting.id %>"
                    class="back"
                >
                    Quay lại
                </a>
            </div>
        </form>
    </div>
</body>
</html>