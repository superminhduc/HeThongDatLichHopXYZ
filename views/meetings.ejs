<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>Danh sách cuộc họp</title>

    <link rel="stylesheet" href="/css/app.css">

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f5f6f8;
            color: #111827;
        }

        .topbar {
            height: 72px;
            padding: 0 35px;
            background: white;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .logo {
            color: #111827;
            font-size: 20px;
            font-weight: 700;
            text-decoration: none;
        }

        .topbar-actions {
            display: flex;
            gap: 10px;
        }

        .page {
            max-width: 1200px;
            margin: 32px auto;
            padding: 0 20px;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 20px;
            margin-bottom: 24px;
        }

        .page-header h1 {
            margin: 0 0 8px;
            font-size: 28px;
        }

        .page-header p {
            margin: 0;
            color: #6b7280;
        }

        .button {
            display: inline-block;
            padding: 11px 16px;
            border: none;
            border-radius: 9px;
            font: inherit;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
        }

        .button-primary {
            background: #111827;
            color: white;
        }

        .button-secondary {
            background: #e5e7eb;
            color: #111827;
        }

        .button-detail {
            background: #2563eb;
            color: white;
        }

        .button-complete {
            background: #15803d;
            color: white;
        }

        .button-cancel {
            background: #dc2626;
            color: white;
        }

        .message {
            margin-bottom: 20px;
            padding: 14px 16px;
            border: 1px solid #bbf7d0;
            border-radius: 10px;
            background: #f0fdf4;
            color: #166534;
        }

        .meeting-list {
            display: grid;
            gap: 18px;
        }

        .meeting-card {
            padding: 22px;
            background: white;
            border: 1px solid #e5e7eb;
            border-radius: 14px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.04);
        }

        .meeting-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 18px;
            margin-bottom: 18px;
        }

        .meeting-title {
            margin: 0 0 8px;
            font-size: 20px;
        }

        .meeting-description {
            margin: 0;
            color: #6b7280;
            line-height: 1.6;
        }

        .status {
            display: inline-block;
            flex-shrink: 0;
            padding: 7px 11px;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 700;
        }

        .scheduled {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .completed {
            background: #dcfce7;
            color: #15803d;
        }

        .cancelled {
            background: #fee2e2;
            color: #b91c1c;
        }

        .meeting-info {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 14px;
            margin-bottom: 18px;
        }

        .info-item {
            padding: 13px;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            background: #fafafa;
        }

        .info-label {
            display: block;
            margin-bottom: 6px;
            color: #6b7280;
            font-size: 12px;
            font-weight: 600;
        }

        .info-value {
            font-size: 14px;
            font-weight: 600;
            line-height: 1.5;
        }

        .meeting-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 9px;
            padding-top: 17px;
            border-top: 1px solid #e5e7eb;
        }

        .meeting-actions form {
            margin: 0;
        }

        .empty {
            padding: 50px 20px;
            background: white;
            border: 1px dashed #d1d5db;
            border-radius: 14px;
            color: #6b7280;
            text-align: center;
        }

        @media (max-width: 900px) {
            .meeting-info {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 650px) {
            .topbar {
                height: auto;
                padding: 16px;
                flex-direction: column;
                align-items: stretch;
                gap: 14px;
            }

            .topbar-actions {
                flex-direction: column;
            }

            .topbar-actions .button {
                text-align: center;
            }

            .page {
                margin: 22px auto;
                padding: 0 12px;
            }

            .page-header,
            .meeting-header {
                flex-direction: column;
            }

            .meeting-info {
                grid-template-columns: 1fr;
            }

            .meeting-actions {
                flex-direction: column;
            }

            .meeting-actions .button,
            .meeting-actions form,
            .meeting-actions form button {
                width: 100%;
                text-align: center;
            }
        }
    </style>
</head>

<body>
    <header class="topbar">
        <a href="/" class="logo">
            Meeting System
        </a>

        <div class="topbar-actions">
            <a
                href="/meetings/calendar"
                class="button button-secondary"
            >
                Xem lịch
            </a>

            <a
                href="/meetings/create"
                class="button button-primary"
            >
                + Tạo cuộc họp
            </a>
        </div>
    </header>

    <main class="page">
        <div class="page-header">
            <div>
                <h1>Danh sách cuộc họp</h1>

                <p>
                    Theo dõi và quản lý toàn bộ lịch họp của công ty.
                </p>
            </div>
        </div>

        <% if (message) { %>
            <div class="message">
                <%= message %>
            </div>
        <% } %>

        <% if (meetings.length === 0) { %>
            <div class="empty">
                <h3>Chưa có cuộc họp nào</h3>

                <p>
                    Hãy tạo cuộc họp đầu tiên cho hệ thống.
                </p>

                <a
                    href="/meetings/create"
                    class="button button-primary"
                >
                    Tạo cuộc họp
                </a>
            </div>
        <% } else { %>
            <div class="meeting-list">
                <% meetings.forEach(meeting => { %>
                    <article class="meeting-card">
                        <div class="meeting-header">
                            <div>
                                <h2 class="meeting-title">
                                    <%= meeting.title %>
                                </h2>

                                <p class="meeting-description">
                                    <%= meeting.description ||
                                        "Không có mô tả." %>
                                </p>
                            </div>

                            <span class="status <%= meeting.status %>">
                                <% if (meeting.status === "scheduled") { %>
                                    Đã lên lịch
                                <% } else if (
                                    meeting.status === "completed"
                                ) { %>
                                    Đã hoàn thành
                                <% } else if (
                                    meeting.status === "cancelled"
                                ) { %>
                                    Đã hủy
                                <% } else { %>
                                    <%= meeting.status %>
                                <% } %>
                            </span>
                        </div>

                        <div class="meeting-info">
                            <div class="info-item">
                                <span class="info-label">
                                    Ngày họp
                                </span>

                                <div class="info-value">
                                    <%= new Date(
                                        meeting.meeting_date
                                    ).toLocaleDateString("vi-VN") %>
                                </div>
                            </div>

                            <div class="info-item">
                                <span class="info-label">
                                    Thời gian
                                </span>

                                <div class="info-value">
                                    <%= String(
                                        meeting.start_time
                                    ).substring(0, 5) %>

                                    -

                                    <%= String(
                                        meeting.end_time
                                    ).substring(0, 5) %>
                                </div>
                            </div>

                            <div class="info-item">
                                <span class="info-label">
                                    Phòng họp
                                </span>

                                <div class="info-value">
                                    <%= meeting.room ||
                                        "Chưa cập nhật" %>
                                </div>
                            </div>

                            <div class="info-item">
                                <span class="info-label">
                                    Địa điểm
                                </span>

                                <div class="info-value">
                                    <%= meeting.location %>
                                </div>
                            </div>

                            <div class="info-item">
                                <span class="info-label">
                                    Người tổ chức
                                </span>

                                <div class="info-value">
                                    <%= meeting.organizer_name %>
                                </div>
                            </div>
                        </div>

                        <div class="meeting-actions">
                            <a
                                href="/meetings/<%= meeting.id %>"
                                class="button button-detail"
                            >
                                Xem chi tiết
                            </a>

                            <% if (
                                meeting.status === "scheduled"
                            ) { %>
                                <a
                                    href="/meetings/<%= meeting.id %>/edit"
                                    class="button button-secondary"
                                >
                                    Sửa
                                </a>

                                <form
                                    action="/meetings/<%= meeting.id %>/complete"
                                    method="POST"
                                    onsubmit="return confirm(
                                        'Bạn có chắc muốn đánh dấu cuộc họp này đã hoàn thành?'
                                    )"
                                >
                                    <button
                                        type="submit"
                                        class="button button-complete"
                                    >
                                        Hoàn thành
                                    </button>
                                </form>

                                <form
                                    action="/meetings/<%= meeting.id %>/cancel"
                                    method="POST"
                                    onsubmit="return confirm(
                                        'Bạn có chắc muốn hủy cuộc họp này?'
                                    )"
                                >
                                    <button
                                        type="submit"
                                        class="button button-cancel"
                                    >
                                        Hủy cuộc họp
                                    </button>
                                </form>
                            <% } %>
                        </div>
                    </article>
                <% }) %>
            </div>
        <% } %>
    </main>
</body>
</html>