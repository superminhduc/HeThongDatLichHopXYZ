<!DOCTYPE html><html lang="vi"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Dashboard lịch họp</title><link rel="stylesheet" href="/css/app.css"></head><body>
<header class="app-shell-header"><div class="app-shell-top"><div class="shell-inner"><a href="/" class="app-shell-brand"><svg class="icon icon-lg brand-mark" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4M8 3v4M3 11h18"/></svg><span>Hệ Thống Đặt Lịch Họp</span></a><a href="/meetings/create" class="shell-create"><svg class="icon" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>Tạo Cuộc Họp</a></div></div><nav class="app-shell-nav"><div class="nav-inner"><a class="nav-link active" href="/"><svg class="icon" viewBox="0 0 24 24"><path d="m3 11 9-8 9 8"/><path d="M5 10v10h14V10M9 20v-6h6v6"/></svg><span class="nav-text">Trang Chủ</span></a><a class="nav-link" href="/meetings"><svg class="icon" viewBox="0 0 24 24"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/></svg><span class="nav-text">Danh Sách Cuộc Họp</span></a><a class="nav-link" href="/meetings/calendar"><svg class="icon" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4M8 3v4M3 11h18"/></svg><span class="nav-text">Lịch Cuộc Họp</span></a></div></nav></header>
<main class="page-shell"><section class="stats-grid"><div class="card stat-card"><div class="stat-title"><span>Hôm Nay</span><svg class="icon" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4M8 3v4M3 11h18"/></svg></div><div class="stat-number"><%= stats.today_count || 0 %></div><div class="stat-caption">cuộc họp đã lên lịch</div></div><div class="card stat-card"><div class="stat-title"><span>Sắp Tới</span><svg class="icon" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></div><div class="stat-number"><%= stats.upcoming_count || 0 %></div><div class="stat-caption">cuộc họp được lên lịch</div></div><div class="card stat-card"><div class="stat-title"><span>Đã Hoàn Thành</span><svg class="icon" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="m16 11 2 2 4-4"/></svg></div><div class="stat-number"><%= stats.completed_count || 0 %></div><div class="stat-caption">cuộc họp đã diễn ra</div></div></section>
<section class="dashboard-calendar-grid"><article class="card"><div class="card-head"><h2>Lịch</h2><p>Chọn ngày để xem các cuộc họp</p></div><div class="card-body calendar-card-body"><div class="mini-calendar" id="miniCalendar"></div></div></article><article class="card"><div class="card-head"><h2 id="selectedDateTitle">Cuộc Họp Trong Ngày</h2><p id="selectedDateSub">Không có cuộc họp nào</p></div><div class="card-body selected-meetings" id="selectedDayMeetings"></div></article></section>
<section class="card upcoming-card"><div class="card-head"><div><h2>Cuộc Họp Sắp Tới</h2><p><%= Math.min(upcomingMeetings.length,5) %> cuộc họp tiếp theo</p></div><a class="ghost-button" href="/meetings">Xem Tất Cả<svg class="icon" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg></a></div><div class="card-body"><% if(!upcomingMeetings.length){ %><div class="empty-state" style="min-height:110px">Chưa có cuộc họp sắp tới.</div><% }else{ %><div class="upcoming-list"><% upcomingMeetings.slice(0,5).forEach(meeting=>{ const d=new Date(meeting.meeting_date); %><a href="/meetings/<%= meeting.id %>" class="upcoming-row"><div class="date-box"><div class="month">thg <%= d.getMonth()+1 %></div><div class="day"><%= d.getDate() %></div></div><div class="upcoming-main"><div class="upcoming-name"><%= meeting.title %></div><div class="upcoming-meta"><span>◷ <%= String(meeting.start_time).substring(0,5) %></span><span>⌖ <%= meeting.room || meeting.location %></span><% if(meeting.participant_count){ %><span>♙ <%= meeting.participant_count %> người tham gia</span><% } %></div></div><svg class="icon chevron" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg></a><% }) %></div><% } %></div></section></main>
<script>const meetingDays=<%- JSON.stringify(upcomingMeetings.map(m=>({id:m.id,title:m.title,date:new Date(m.meeting_date).toISOString().slice(0,10),start:String(m.start_time).substring(0,5),end:String(m.end_time||'').substring(0,5),room:m.room||m.location}))).replace(/</g,'\\u003c') %>;let calDate=new Date();let selectedDate=new Date();function keyOf(d){return[d.getFullYear(),String(d.getMonth()+1).padStart(2,'0'),String(d.getDate()).padStart(2,'0')].join('-')}function renderCalendar(){const el=document.getElementById('miniCalendar'),y=calDate.getFullYear(),m=calDate.getMonth(),first=new Date(y,m,1),days=new Date(y,m+1,0).getDate();let h='<div class="mini-cal-head"><button class="mini-cal-arrow" type="button" data-move="-1">‹</button><span class="mini-cal-title">Tháng '+(m+1)+' '+y+'</span><button class="mini-cal-arrow" type="button" data-move="1">›</button></div><div class="mini-cal-grid">';['Th 2','Th 3','Th 4','Th 5','Th 6','Th 7','CN'].forEach(x=>h+='<span class="weekday">'+x+'</span>');for(let i=0;i<(first.getDay()+6)%7;i++)h+='<span></span>';for(let day=1;day<=days;day++){const d=new Date(y,m,day),key=keyOf(d),cls=[];if(key===keyOf(new Date()))cls.push('today');if(key===keyOf(selectedDate))cls.push('selected');if(meetingDays.some(x=>x.date===key))cls.push('has-meeting');h+='<button type="button" class="'+cls.join(' ')+'" data-date="'+key+'">'+day+'</button>'}h+='</div>';el.innerHTML=h;el.querySelectorAll('[data-move]').forEach(b=>b.onclick=()=>{calDate=new Date(y,m+Number(b.dataset.move),1);renderCalendar()});el.querySelectorAll('[data-date]').forEach(b=>b.onclick=()=>{selectedDate=new Date(b.dataset.date+'T00:00:00');showDay(b.dataset.date);renderCalendar()})}function showDay(date){const d=new Date(date+'T00:00:00'),items=meetingDays.filter(x=>x.date===date),title=document.getElementById('selectedDateTitle'),sub=document.getElementById('selectedDateSub'),box=document.getElementById('selectedDayMeetings');title.textContent='Cuộc Họp Ngày '+d.toLocaleDateString('vi-VN',{day:'numeric',month:'long',year:'numeric'});sub.textContent=items.length?items.length+' cuộc họp':'Không có cuộc họp nào';if(!items.length){box.innerHTML='<div class="empty-state"><svg class="icon icon-xl" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4M8 3v4M3 11h18"/></svg><span>Chưa có cuộc họp nào được lên lịch</span></div>';return}box.innerHTML='<div class="day-meeting-list">'+items.map(x=>'<a class="day-meeting-item" href="/meetings/'+x.id+'"><div class="time-icon"><svg class="icon icon-lg" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></div><div class="day-meeting-main"><strong>'+x.title+'</strong><div class="meta-line">◷ '+x.start+(x.end?' - '+x.end:'')+'</div><div class="meta-line">⌖ '+x.room+'</div></div><svg class="icon chevron" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg></a>').join('')+'</div>'}renderCalendar();showDay(keyOf(selectedDate));</script></body></html>
