<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Chi tiết cuộc họp</title>
    <link rel="stylesheet" href="/css/app.css">
</head>

<body>
    <header class="app-shell-header">
        <div class="app-shell-top">
            <div class="shell-inner">
                <a href="/" class="app-shell-brand">
                    <span class="brand-mark">▣</span>
                    <span>Hệ Thống Đặt Lịch Họp</span>
                </a>

                <a href="/meetings/create" class="shell-create">
                    ＋ Tạo Cuộc Họp
                </a>
            </div>
        </div>

        <nav class="app-shell-nav">
            <div class="nav-inner">
                <a class="nav-link" href="/">Trang Chủ</a>
                <a class="nav-link active" href="/meetings">
                    Danh Sách Cuộc Họp
                </a>
            </div>
        </nav>
    </header>

    <main class="page-shell">
        <a href="/meetings" class="back-link">←</a>

        <% if (message) { %>
            <div class="alert alert-success">
                <%= message %>
            </div>
        <% } %>

        <%
            let statusText = meeting.status;

            if (meeting.status === "scheduled") {
                statusText = "Đã lên lịch";
            } else if (meeting.status === "completed") {
                statusText = "Đã hoàn thành";
            } else if (meeting.status === "cancelled") {
                statusText = "Đã hủy";
            }
        %>

        <div class="detail-heading">
            <div>
                <div class="detail-title-line">
                    <h1><%= meeting.title %></h1>

                    <span class="status <%= meeting.status %>">
                        <%= statusText %>
                    </span>
                </div>

                <div class="detail-subtitle">
                    Chi tiết cuộc họp
                </div>
            </div>

            <div class="icon-actions">
                <% if (meeting.status === "scheduled") { %>
                    <a
                        href="/meetings/<%= meeting.id %>/edit"
                        class="icon-button"
                        title="Sửa"
                    >
                        ✎
                    </a>
                <% } %>
            </div>
        </div>

        <div class="detail-grid">
            <div class="detail-main">
                <section class="card">
                    <div class="card-head">
                        <h2>Thông Tin Cuộc Họp</h2>
                    </div>

                    <div class="detail-info-list">
                        <div class="detail-info-row">
                            <div class="detail-icon blue">▣</div>

                            <div>
                                <div class="detail-label">Ngày</div>

                                <div class="detail-value">
                                    <%= new Date(
                                        meeting.meeting_date
                                    ).toLocaleDateString(
                                        "vi-VN",
                                        {
                                            weekday: "long",
                                            year: "numeric",
                                            month: "long",
                                            day: "numeric"
                                        }
                                    ) %>
                                </div>
                            </div>
                        </div>

                        <div class="detail-info-row">
                            <div class="detail-icon green">◷</div>

                            <div>
                                <div class="detail-label">Thời gian</div>

                                <div class="detail-value">
                                    <%= String(meeting.start_time).substring(0, 5) %>
                                    -
                                    <%= String(meeting.end_time).substring(0, 5) %>
                                </div>
                            </div>
                        </div>

                        <div class="detail-info-row">
                            <div class="detail-icon purple">⌖</div>

                            <div>
                                <div class="detail-label">Địa điểm</div>

                                <div class="detail-value">
                                    <%= meeting.room || "Chưa cập nhật" %>

                                    <% if (meeting.location) { %>
                                        - <%= meeting.location %>
                                    <% } %>
                                </div>
                            </div>
                        </div>

                        <div class="detail-info-row">
                            <div class="detail-icon orange">♙</div>

                            <div>
                                <div class="detail-label">
                                    Người tổ chức
                                </div>

                                <div class="detail-value">
                                    <%= meeting.organizer_name %>
                                </div>
                            </div>
                        </div>

                        <% if (meeting.description) { %>
                            <div class="description-block">
                                <div class="detail-label">Mô tả</div>

                                <p><%= meeting.description %></p>
                            </div>
                        <% } %>
                    </div>
                </section>

                <% if (meeting.status === "scheduled") { %>
                    <section class="card action-card">
                        <div class="card-head">
                            <h2>Hành Động</h2>
                            <p>Cập nhật trạng thái cuộc họp</p>
                        </div>

                        <div class="card-body">
                            <form
                                action="/meetings/<%= meeting.id %>/complete"
                                method="POST"
                                onsubmit="return confirm('Bạn có chắc muốn đánh dấu cuộc họp này đã hoàn thành?')"
                            >
                                <button
                                    class="button button-success"
                                    type="submit"
                                >
                                    ✓ Đánh Dấu Hoàn Thành
                                </button>
                            </form>

                            <form
                                action="/meetings/<%= meeting.id %>/cancel"
                                method="POST"
                                onsubmit="return confirm('Bạn có chắc muốn hủy cuộc họp này?')"
                            >
                                <button
                                    class="button button-danger"
                                    type="submit"
                                >
                                    ⊗ Hủy Cuộc Họp
                                </button>
                            </form>
                        </div>
                    </section>
                <% } %>
            </div>

            <aside class="detail-side">
                <section class="card">
                    <div class="card-head">
                        <h2>♙ Người Tham Gia</h2>
                        <p><%= participants.length %> người</p>
                    </div>

                    <div class="card-body">
                        <% if (!participants.length) { %>
                            <div
                                class="empty-state"
                                style="min-height: 120px;"
                            >
                                Chưa có người tham gia.
                            </div>
                        <% } else { %>
                            <div class="participant-list">
                                <% participants.forEach(person => { %>
                                    <%
                                        const initials = (
                                            person.full_name || "?"
                                        )
                                            .trim()
                                            .split(/\s+/)
                                            .slice(-1)[0]
                                            .charAt(0)
                                            .toUpperCase();

                                        const participantInfo = [
                                            person.department,
                                            person.position
                                        ]
                                            .filter(Boolean)
                                            .join(" • ");
                                    %>

                                    <div class="participant-chip">
                                        <div class="avatar">
                                            <%= initials %>
                                        </div>

                                        <div>
                                            <div class="participant-name">
                                                <%= person.full_name %>
                                            </div>

                                            <div class="participant-extra">
                                                <%= participantInfo %>
                                            </div>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>
                </section>

                <section class="card">
                    <div class="card-head">
                        <h2>Thông Tin Bổ Sung</h2>
                    </div>

                    <div class="card-body extra-info">
                        <div class="extra-row">
                            <span>Trạng thái:</span>
                            <strong><%= statusText %></strong>
                        </div>

                        <div class="extra-row">
                            <span>Thời lượng:</span>
                            <strong id="durationValue">—</strong>
                        </div>

                        <div class="extra-row">
                            <span>Số người:</span>
                            <strong><%= participants.length %></strong>
                        </div>
                    </div>
                </section>
            </aside>
        </div>
    </main>

    <script>
        (function () {
            const startTime =
                "<%= String(meeting.start_time).substring(0, 5) %>";

            const endTime =
                "<%= String(meeting.end_time).substring(0, 5) %>";

            const [startHour, startMinute] =
                startTime.split(":").map(Number);

            const [endHour, endMinute] =
                endTime.split(":").map(Number);

            const totalMinutes =
                (endHour * 60 + endMinute) -
                (startHour * 60 + startMinute);

            const durationElement =
                document.getElementById("durationValue");

            if (!durationElement || totalMinutes < 0) {
                return;
            }

            const hours =
                Math.floor(totalMinutes / 60);

            const minutes =
                totalMinutes % 60;

            durationElement.textContent =
                (hours ? `${hours}h ` : "") +
                (minutes ? `${minutes}m` : "0m");
        })();
    </script>
</body>

</html>
