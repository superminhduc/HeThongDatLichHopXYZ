<!DOCTYPE html><html lang="vi"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Lịch cuộc họp</title><script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.19/index.global.min.js"></script><link rel="stylesheet" href="/css/app.css"></head><body>
<header class="app-shell-header"><div class="app-shell-top"><div class="shell-inner"><a href="/" class="app-shell-brand"><span class="brand-mark">▣</span><span>Hệ Thống Đặt Lịch Họp</span></a><a href="/meetings/create" class="shell-create">＋ Tạo Cuộc Họp</a></div></div><nav class="app-shell-nav"><div class="nav-inner"><a class="nav-link" href="/">Trang Chủ</a><a class="nav-link" href="/meetings">Danh Sách Cuộc Họp</a><a class="nav-link active" href="/meetings/calendar">Lịch Cuộc Họp</a></div></nav></header>
<main class="page-shell"><div class="page-heading"><div><h1>Lịch Cuộc Họp</h1><p>Theo dõi lịch họp theo tháng, tuần hoặc ngày.</p></div></div><div class="legend"><span class="legend-item"><i class="legend-dot blue"></i>Đã lên lịch</span><span class="legend-item"><i class="legend-dot green"></i>Đã hoàn thành</span><span class="legend-item"><i class="legend-dot red"></i>Đã hủy</span></div><div id="loadingMessage" class="loading">Đang tải dữ liệu lịch họp...</div><div id="calendarError" class="calendar-error">Không thể tải dữ liệu lịch họp.</div><section class="calendar-layout"><div class="card calendar-card"><div id="calendar"></div></div><aside class="card calendar-side"><div class="card-head"><h2 id="sideTitle">Cuộc Họp Trong Ngày</h2><p id="sideSubtitle">Chọn một ngày trên lịch</p></div><div class="card-body" id="sideMeetings"><div class="empty-state"><span>Chọn ngày để xem cuộc họp</span></div></div></aside></section></main><div id="meetingTooltip" class="meeting-tooltip"></div>
<script>document.addEventListener('DOMContentLoaded',function(){const calendarElement=document.getElementById('calendar'),loadingMessage=document.getElementById('loadingMessage'),calendarError=document.getElementById('calendarError'),tooltip=document.getElementById('meetingTooltip'),sideTitle=document.getElementById('sideTitle'),sideSubtitle=document.getElementById('sideSubtitle'),sideMeetings=document.getElementById('sideMeetings');let loadedEvents=[];function renderSide(dateStr){const date=new Date(dateStr+'T00:00:00'),items=loadedEvents.filter(ev=>{const d=ev.start instanceof Date?ev.start:new Date(ev.start);return d.getFullYear()===date.getFullYear()&&d.getMonth()===date.getMonth()&&d.getDate()===date.getDate()});sideTitle.textContent='Cuộc Họp Ngày '+date.toLocaleDateString('vi-VN');sideSubtitle.textContent=items.length?items.length+' cuộc họp':'Không có cuộc họp nào';if(!items.length){sideMeetings.innerHTML='<div class="empty-state"><span>Chưa có cuộc họp nào được lên lịch</span><a class="button button-primary" style="margin-top:14px" href="/meetings/create?date='+dateStr+'">Tạo Cuộc Họp</a></div>';return}sideMeetings.innerHTML='<div class="day-meeting-list">'+items.map(ev=>{const p=ev.extendedProps||{},start=ev.start?ev.start.toLocaleTimeString('vi-VN',{hour:'2-digit',minute:'2-digit'}):'';return '<a href="/meetings/'+ev.id+'" class="day-meeting-item"><div class="time-icon">◷</div><div class="day-meeting-main"><strong>'+ev.title+'</strong><div class="meta-line">'+start+'</div><div class="meta-line">'+(p.room||p.location||'Chưa cập nhật')+'</div></div><span class="chevron">›</span></a>'}).join('')+'</div>'}const calendar=new FullCalendar.Calendar(calendarElement,{initialView:'dayGridMonth',locale:'vi',firstDay:1,height:'auto',nowIndicator:true,selectable:true,dayMaxEvents:true,headerToolbar:{left:'prev,next today',center:'title',right:'dayGridMonth,timeGridWeek,timeGridDay'},buttonText:{today:'Hôm nay',month:'Tháng',week:'Tuần',day:'Ngày'},allDayText:'Cả ngày',slotMinTime:'07:00:00',slotMaxTime:'22:00:00',events:{url:'/meetings/calendar/events',method:'GET',success:function(events){loadedEvents=events.map(e=>({...e,start:e.start?new Date(e.start):null,end:e.end?new Date(e.end):null}));renderSide(new Date().toISOString().slice(0,10))},failure:function(){calendarError.style.display='block'}},loading:function(isLoading){loadingMessage.style.display=isLoading?'block':'none'},eventClassNames:function(info){const status=info.event.extendedProps.status;return[status==='completed'?'event-completed':status==='cancelled'?'event-cancelled':'event-scheduled']},eventMouseEnter:function(info){const p=info.event.extendedProps,start=info.event.start?info.event.start.toLocaleTimeString('vi-VN',{hour:'2-digit',minute:'2-digit'}):'',end=info.event.end?info.event.end.toLocaleTimeString('vi-VN',{hour:'2-digit',minute:'2-digit'}):'';tooltip.innerHTML='<strong>'+info.event.title+'</strong><br>Thời gian: '+start+(end?' - '+end:'')+'<br>Địa điểm: '+(p.location||'Chưa cập nhật')+'<br>Phòng: '+(p.room||'Chưa cập nhật')+'<br>Người tổ chức: '+(p.organizer||'Chưa cập nhật');tooltip.style.display='block'},eventMouseLeave:function(){tooltip.style.display='none'},eventMouseMove:function(e){tooltip.style.left=e.jsEvent.clientX+15+'px';tooltip.style.top=e.jsEvent.clientY+15+'px'},eventClick:function(info){info.jsEvent.preventDefault();window.location.href='/meetings/'+info.event.id},dateClick:function(info){renderSide(info.dateStr)},select:function(info){const selectedDate=info.startStr.split('T')[0],startTime=info.startStr.includes('T')?info.startStr.split('T')[1].substring(0,5):'',endTime=info.endStr.includes('T')?info.endStr.split('T')[1].substring(0,5):'';if(startTime||endTime){const query=new URLSearchParams({date:selectedDate,start:startTime,end:endTime});window.location.href='/meetings/create?'+query.toString()}else renderSide(selectedDate)}});calendar.render()});</script></body></html>
